NODE_ENV=development
PORT=5050
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/biztrack?schema=public"
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="7d"
CONFIG_ENCRYPTION_KEY="replace-with-a-long-random-config-encryption-key"
APP_URL="http://127.0.0.1:5173"
EMAIL_PROVIDER="SMTP"
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT=587
EMAIL_USERNAME="your-gmail-address@gmail.com"
EMAIL_PASSWORD="your-google-app-password"
EMAIL_FROM_NAME="BizTrack"
EMAIL_FROM_EMAIL="your-gmail-address@gmail.com"
EMAIL_REPLY_TO="your-gmail-address@gmail.com"
EMAIL_LOGO_PATH="./assets/biztrack-logo.png"
SUPER_ADMIN_NAME="System Admin"
SUPER_ADMIN_EMAIL="admin@example.com"
SUPER_ADMIN_PASSWORD="change-this-password"
OPENAI_API_KEY=""
CORS_ORIGIN="http://127.0.0.1:5173,http://localhost:5173"
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=20
AUTH_EMAIL_RATE_LIMIT_WINDOW_MS=60000
AUTH_EMAIL_RATE_LIMIT_MAX=5
